<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record model="ir.module.category" id="module_category_cong_viec">
        <field name="name">Quản Lý Công Việc</field>
        <field name="sequence">10</field>
    </record>

    <!-- ========== NHÓM QUYỀN MODULE CÔNG VIỆC ========== -->
    <record id="group_cong_viec_user" model="res.groups">
        <field name="name">Nhân Viên</field>
        <field name="category_id" ref="module_category_cong_viec"/>
        <field name="comment">Xem công việc được giao, cập nhật tiến độ</field>
    </record>

    <record id="group_cong_viec_manager" model="res.groups">
        <field name="name">Quản Lý Công Việc</field>
        <field name="category_id" ref="module_category_cong_viec"/>
        <field name="implied_ids" eval="[(4, ref('group_cong_viec_user'))]"/>
        <field name="comment">Tạo, phân công, đánh giá công việc cho nhân viên</field>
    </record>

    <record id="group_cong_viec_admin" model="res.groups">
        <field name="name">Quản Trị Công Việc</field>
        <field name="category_id" ref="module_category_cong_viec"/>
        <field name="implied_ids" eval="[(4, ref('group_cong_viec_manager'))]"/>
        <field name="comment">Toàn quyền quản lý, xem báo cáo và cấu hình hệ thống</field>
        <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

</odoo>
