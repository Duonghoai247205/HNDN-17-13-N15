<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Mở rộng form nhân viên (hr.employee):
        Thêm thống kê công việc vào button_box và tab mới.
        Module quan_ly_cong_viec chỉ thêm phần liên quan đến công việc.
        Phần dự án sẽ được bổ sung bởi module quan_ly_du_an.
    -->
    <record id="view_employee_form_inherit_cong_viec" model="ir.ui.view">
        <field name="name">nhan_vien.form.inherit.cong_viec</field>
        <field name="model">nhan_vien</field>
        <field name="inherit_id" ref="nhan_su.view_nhan_vien_form"/>
        <field name="arch" type="xml">

            <!-- Thêm nút thống kê Công Việc vào button_box -->
            <xpath expr="//sheet/div[@class='oe_read_only']" position="after">
                <div class="oe_button_box" name="button_box">
                    <button name="action_view_tasks" type="object"
                            class="oe_stat_button" icon="fa-check-square-o"
                            groups="quan_ly_cong_viec.group_cong_viec_user">
                        <field name="task_count" widget="statinfo" string="Công Việc"/>
                    </button>
                </div>
            </xpath>

            <!-- Thêm tab Công Việc sau tab Work Information -->
            <xpath expr="//notebook" position="inside">
                <page name="cong_viec_tab" string="Công Việc &amp; KPI">
                    <group>
                        <group string="Thống Kê Công Việc">
                            <field name="task_count" string="Tổng Công Việc" readonly="1"/>
                            <field name="task_done_count" string="Đã Hoàn Thành" readonly="1"/>
                            <field name="performance_avg" string="Hiệu Quả TB (%)" readonly="1"/>
                        </group>
                    </group>

                    <separator string="Danh Sách Công Việc"/>
                    <field name="task_ids" readonly="1">
                        <tree string="Công Việc Được Giao"
                              decoration-danger="is_overdue == True"
                              decoration-success="state == 'done'"
                              decoration-muted="state == 'cancelled'">
                            <field name="code"/>
                            <field name="name"/>
                            <field name="date_start"/>
                            <field name="date_deadline"/>
                            <field name="state" widget="badge"
                                   decoration-info="state == 'todo'"
                                   decoration-primary="state == 'in_progress'"
                                   decoration-warning="state == 'review'"
                                   decoration-success="state == 'done'"
                                   decoration-danger="state == 'cancelled'"/>
                            <field name="progress" widget="progressbar"/>
                            <field name="performance_score"/>
                            <field name="is_overdue" invisible="1"/>
                        </tree>
                    </field>
                </page>
            </xpath>

        </field>
    </record>

</odoo>
