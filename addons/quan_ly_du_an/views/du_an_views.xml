<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ========== FORM VIEW ========== -->
    <record id="view_du_an_form" model="ir.ui.view">
        <field name="name">project.du_an.form</field>
        <field name="model">project.du_an</field>
        <field name="arch" type="xml">
            <form string="Dự Án">
                <header>
                    <button name="action_confirm" string="Xác Nhận" type="object"
                            class="btn-primary"
                            attrs="{'invisible': [('state', '!=', 'draft')]}"/>
                    <button name="action_start" string="Bắt Đầu" type="object"
                            class="btn-primary"
                            attrs="{'invisible': [('state', '!=', 'confirmed')]}"/>
                    <button name="action_done" string="Hoàn Thành" type="object"
                            class="btn-success"
                            attrs="{'invisible': [('state', '!=', 'in_progress')]}"/>
                    <button name="action_cancel" string="Hủy Dự Án" type="object"
                            class="btn-danger"
                            attrs="{'invisible': [('state', 'in', ['done', 'cancelled'])]}"/>
                    <button name="action_reset_draft" string="Đặt Lại" type="object"
                            attrs="{'invisible': [('state', '!=', 'cancelled')]}"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed,in_progress,done"/>
                </header>

                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_tasks" type="object"
                                class="oe_stat_button" icon="fa-tasks">
                            <field name="task_count" widget="statinfo" string="Công Việc"/>
                        </button>
                        <button name="action_view_members" type="object"
                                class="oe_stat_button" icon="fa-users">
                            <field name="member_count" widget="statinfo" string="Thành Viên"/>
                        </button>
                    </div>

                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" placeholder="Tên dự án..."/>
                        </h1>
                        <div class="o_row">
                            <field name="code" placeholder="Mã dự án (tự động)"/>
                            <field name="priority" widget="priority"/>
                        </div>
                    </div>

                    <group>
                        <group string="Thông Tin Dự Án">
                            <field name="manager_id" options="{'no_create': True}"/>
                            <field name="department_id" readonly="1"/>
                            <field name="date_start"/>
                            <field name="date_end"/>
                            <field name="duration" readonly="1"/>
                            <field name="is_overdue" widget="boolean_toggle" readonly="1"
                                   attrs="{'invisible': [('state', 'in', ['done', 'cancelled'])]}"/>
                        </group>
                        <group string="Ngân Sách">
                            <field name="budget" widget="monetary"
                                   options="{'currency_field': False}"/>
                            <field name="actual_cost" widget="monetary"
                                   options="{'currency_field': False}"/>
                            <field name="budget_remaining" widget="monetary"
                                   options="{'currency_field': False}" readonly="1"/>
                        </group>
                    </group>

                    <group string="Tiến Độ">
                        <field name="completion_rate" widget="progressbar" readonly="1"/>
                        <field name="task_done_count" readonly="1"/>
                        <field name="task_count" readonly="1"/>
                    </group>

                    <notebook>
                        <page string="Thành Viên Dự Án" name="members">
                            <field name="member_ids"
                                   widget="many2many_tags"
                                   options="{'no_create': True}"/>
                            <separator/>
                            <field name="member_ids">
                                <tree string="Danh Sách Thành Viên">
                                    <field name="ho_ten"/>
                                    <field name="chuc_vu_id"/>
                                    <field name="phong_ban_id"/>
                                    <field name="email"/>
                                    <field name="so_dien_thoai"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Mô Tả" name="description">
                            <field name="description" placeholder="Mô tả chi tiết về dự án..."/>
                        </page>
                        <page string="Ghi Chú" name="notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>

                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ========== LIST/TREE VIEW ========== -->
    <record id="view_du_an_tree" model="ir.ui.view">
        <field name="name">project.du_an.tree</field>
        <field name="model">project.du_an</field>
        <field name="arch" type="xml">
            <tree string="Danh Sách Dự Án" decoration-danger="is_overdue == True"
                  decoration-success="state == 'done'"
                  decoration-muted="state == 'cancelled'">
                <field name="code"/>
                <field name="name"/>
                <field name="manager_id"/>
                <field name="department_id"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'confirmed'"
                       decoration-primary="state == 'in_progress'"
                       decoration-success="state == 'done'"
                       decoration-danger="state == 'cancelled'"/>
                <field name="priority" widget="priority"/>
                <field name="completion_rate" widget="progressbar"/>
                <field name="task_count" string="CV"/>
                <field name="member_count" string="TV"/>
                <field name="is_overdue" invisible="1"/>
            </tree>
        </field>
    </record>

    <!-- ========== KANBAN VIEW ========== -->
    <record id="view_du_an_kanban" model="ir.ui.view">
        <field name="name">project.du_an.kanban</field>
        <field name="model">project.du_an</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" default_group_by="state"
                    group_create="false">
                <field name="name"/>
                <field name="code"/>
                <field name="state"/>
                <field name="priority"/>
                <field name="manager_id"/>
                <field name="date_end"/>
                <field name="completion_rate"/>
                <field name="task_count"/>
                <field name="is_overdue"/>
                <field name="color"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_global_click #{record.is_overdue.raw_value ? 'border-danger' : ''}">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="name"/>
                                        </strong>
                                        <small class="o_kanban_record_subtitle text-muted">
                                            <field name="code"/>
                                        </small>
                                    </div>
                                    <field name="priority" widget="priority"/>
                                </div>
                                <div class="o_kanban_record_body">
                                    <div>
                                        <span class="fa fa-user"/> <field name="manager_id"/>
                                    </div>
                                    <div>
                                        <span class="fa fa-calendar"/> Hạn: <field name="date_end"/>
                                    </div>
                                    <div class="mt-2">
                                        <field name="completion_rate" widget="progressbar"/>
                                    </div>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <span class="badge badge-secondary">
                                            <field name="task_count"/> CV
                                        </span>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <field name="is_overdue" invisible="1"/>
                                        <span t-if="record.is_overdue.raw_value"
                                              class="badge badge-danger">Quá Hạn</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ========== SEARCH VIEW ========== -->
    <record id="view_du_an_search" model="ir.ui.view">
        <field name="name">project.du_an.search</field>
        <field name="model">project.du_an</field>
        <field name="arch" type="xml">
            <search string="Tìm Kiếm Dự Án">
                <field name="name" string="Tên Dự Án"/>
                <field name="code" string="Mã Dự Án"/>
                <field name="manager_id" string="Quản Lý"/>
                <field name="department_id" string="Phòng Ban"/>
                <filter string="Đang Thực Hiện" name="in_progress"
                        domain="[('state', '=', 'in_progress')]"/>
                <filter string="Đã Hoàn Thành" name="done"
                        domain="[('state', '=', 'done')]"/>
                <filter string="Quá Hạn" name="overdue"
                        domain="[('is_overdue', '=', True)]"/>

                <separator/>
                <group expand="0" string="Nhóm Theo">
                    <filter string="Trạng Thái" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Phòng Ban" name="group_dept" context="{'group_by': 'department_id'}"/>
                    <filter string="Quản Lý" name="group_manager" context="{'group_by': 'manager_id'}"/>
                    <filter string="Độ Ưu Tiên" name="group_priority" context="{'group_by': 'priority'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ========== ACTION ========== -->
    <record id="action_du_an" model="ir.actions.act_window">
        <field name="name">Dự Án</field>
        <field name="res_model">project.du_an</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_du_an_search"/>
        <field name="context">{'search_default_in_progress': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Tạo dự án mới
            </p>
            <p>
                Quản lý toàn bộ dự án, phân công nhân sự và theo dõi tiến độ.
            </p>
        </field>
    </record>

</odoo>
